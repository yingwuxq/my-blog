---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { SITE } from "../lib/blog-data.js";
---

<BaseLayout
  title={`关于 - ${SITE.name}`}
  description={`关于 ${SITE.name}`}
  canonical="/about"
>
  <div class="mx-auto max-w-3xl px-5 py-12">
    <Breadcrumbs items={[{ label: "首页", to: "/" }, { label: "关于" }]} />

    <header class="mt-6">
      <div class="text-xs font-medium uppercase tracking-[0.2em] text-primary">About</div>
      <h1 class="mt-2 font-serif text-5xl font-semibold leading-[1.05]">
        {SITE.name}
      </h1>
    </header>

    <div class="prose-article mt-10">
      <p>
        {SITE.name} 是一个个人技术博客，记录深度学习、机器学习与工程实践的学习笔记与思考。
      </p>
      <p>
        内容涵盖 Transformer 架构、注意力机制、模型优化、数学基础等方向。所有文章均以 Markdown 编写，追求清晰、深入、可验证的技术写作风格。
      </p>
    </div>
  </div>
</BaseLayout>
