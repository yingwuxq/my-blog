---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import Icon from "../components/Icon.astro";
import {
  SITE,
  categories,
  featuredPost,
  sortedPosts,
  getAuthor,
  getCategory,
  formatDate,
} from "../lib/blog-data.js";

const featured = await featuredPost();
const featuredAuthor = getAuthor(featured.author);
const featuredCategory = getCategory(featured.category);
const latest = (await sortedPosts()).filter((post) => post.slug !== featured.slug);
---

<BaseLayout
  title={`${SITE.name} — 记录技术、设计与思考`}
  description={SITE.description}
  canonical="/"
  flushFooter
>
  <section class="relative -mt-[68px] min-h-[calc(100svh-2rem)] overflow-hidden border-b border-border/60 pt-[68px] sm:min-h-[760px]">
    <picture>
      <source srcSet="/assets/light-hero.avif" media="(prefers-color-scheme: light)" />
      <img
        src="/assets/dark-hero.avif"
        alt=""
        class="absolute inset-0 h-full w-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </picture>

    <!-- Light overlay: bottom gradient fades into page bg -->
    <div
      aria-hidden="true"
      class="absolute inset-0 dark:hidden"
      style="background: linear-gradient(180deg, rgba(249,249,248,0) 20%, rgba(249,249,248,0.05) 30%, rgba(249,249,248,0.15) 40%, rgba(249,249,248,0.30) 48%, rgba(249,249,248,0.48) 56%, rgba(249,249,248,0.65) 64%, rgba(249,249,248,0.78) 72%, rgba(249,249,248,0.88) 80%, rgba(249,249,248,0.95) 88%, rgba(249,249,248,1) 100%)"
    />

    <!-- Dark overlay -->
    <div
      aria-hidden="true"
      class="absolute inset-0 hidden dark:block"
      style="background: linear-gradient(180deg, rgba(14,14,13,0) 20%, rgba(14,14,13,0.08) 30%, rgba(14,14,13,0.18) 40%, rgba(14,14,13,0.32) 48%, rgba(14,14,13,0.50) 56%, rgba(14,14,13,0.65) 64%, rgba(14,14,13,0.78) 72%, rgba(14,14,13,0.88) 80%, rgba(14,14,13,0.95) 88%, rgba(14,14,13,1) 100%)"
    />

    <div
      aria-hidden="true"
      class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-black/45 via-black/18 to-transparent"
    />

    <div class="relative mx-auto flex min-h-[calc(100svh-6rem)] max-w-6xl items-center justify-center px-5 py-20 sm:min-h-[680px] sm:py-24">
      <div class="mx-auto max-w-4xl text-center">
        <h1 class="font-serif text-7xl font-bold leading-[0.92] tracking-tight sm:text-8xl lg:text-9xl">
          <span
            class="hero-title bg-gradient-to-b from-white via-white/95 to-white/70 bg-clip-text text-transparent"
            style="filter: drop-shadow(0 4px 30px rgba(0,0,0,0.35))"
          >
            {SITE.name}
          </span>
        </h1>
        <p class="mx-auto mt-6 max-w-lg text-lg leading-relaxed text-white/80 sm:text-xl">
          记录深度学习、机器学习与工程实践的个人博客。
        </p>
        <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed tracking-wider text-white/60">
          Transformer &middot; Attention &middot; LLM &middot; PyTorch
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-6">
          <a
            href={`/blog/${featured.slug}`}
            class="group inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-medium text-white transition-all duration-200 hover:bg-white/10"
            style="text-shadow: 0 1px 4px rgba(0,0,0,0.25)"
          >
            开始阅读 <Icon name="arrow-right" class="h-3.5 w-3.5 transition-transform duration-200 group-hover:translate-x-1" />
          </a>
          <a
            href="/blog"
            class="inline-flex items-center rounded-lg px-5 py-2.5 text-sm font-medium text-white/80 transition-all duration-200 hover:bg-white/10 hover:text-white"
            style="text-shadow: 0 1px 4px rgba(0,0,0,0.25)"
          >
            浏览所有文章
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Post -->
  <section class="border-b border-border/60">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="mb-6 flex items-center justify-between">
        <div class="text-xs font-medium uppercase tracking-wider text-muted-foreground">推荐</div>
        <a href="/blog" class="text-xs text-muted-foreground hover:text-foreground">所有文章 &rarr;</a>
      </div>
      <article class="grid gap-10 lg:grid-cols-2">
        <a href={`/blog/${featured.slug}`} class="group block overflow-hidden rounded-md" aria-label={featured.title}>
          <div class="aspect-[4/3] overflow-hidden rounded-md bg-muted sm:aspect-square">
            <picture>
              <source srcSet="/assets/light-hero.avif" media="(prefers-color-scheme: light)" />
              <img
                src="/assets/dark-hero.avif"
                alt=""
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                loading="lazy"
              />
            </picture>
          </div>
        </a>
        <div class="flex flex-col justify-center">
          <div class="flex items-center gap-3 text-xs uppercase tracking-wider text-muted-foreground">
            {
              featuredCategory && (
                <a href={`/categories/${featuredCategory.slug}`} class="inline-flex min-h-9 items-center text-primary hover:underline">
                  {featuredCategory.name}
                </a>
              )
            }
            <span>&middot;</span>
            <time datetime={featured.date}>{formatDate(featured.date)}</time>
          </div>
          <a href={`/blog/${featured.slug}`} class="mt-2 block py-1">
            <h2 class="font-serif text-3xl font-semibold leading-tight hover:text-primary sm:text-4xl">
              {featured.title}
            </h2>
          </a>
          <p class="mt-4 text-lg text-muted-foreground">{featured.excerpt}</p>
          <div class="mt-6 flex items-center gap-3 text-sm text-muted-foreground">
            {
              featuredAuthor && (
                <>
                  <img src={featuredAuthor.avatar} alt="" width="28" height="28" class="h-7 w-7 rounded-full" />
                  <span>{featuredAuthor.name}</span>
                  <span>&middot;</span>
                </>
              )
            }
            <span>{featured.readingTime} min read</span>
          </div>
          <a href={`/blog/${featured.slug}`} class="mt-6 inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline">
            阅读全文 <Icon name="arrow-right" class="h-3.5 w-3.5" />
          </a>
        </div>
      </article>
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="mx-auto max-w-6xl px-5 py-16" data-home-latest>
    <div class="flex flex-wrap items-center justify-between gap-4">
      <h2 class="font-serif text-2xl font-semibold">最新文章</h2>
      <div class="flex flex-wrap gap-2">
        <button
          type="button"
          data-home-filter=""
          class="rounded-full border px-3 py-1 text-xs transition-colors border-foreground bg-foreground text-background"
        >
          全部
        </button>
        {
          categories.map((category) => (
            <button
              type="button"
              data-home-filter={category.slug}
              class="rounded-full border px-3 py-1 text-xs transition-colors border-border text-muted-foreground hover:text-foreground"
            >
              {category.name}
            </button>
          ))
        }
      </div>
    </div>

    <div data-home-empty class="mt-12 rounded-md border border-dashed border-border py-16 text-center text-muted-foreground" hidden>
      暂无文章。
    </div>

    <div class="mt-10 grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {latest.map((post, index) => <PostCard post={post} hidden={index >= 6} />)}
    </div>

    <div class="mt-12 text-center">
      <a href="/blog" class="inline-flex items-center gap-2 rounded-md border border-border px-5 py-2.5 text-sm font-medium hover:bg-muted">
        浏览全部 <Icon name="arrow-right" class="h-3.5 w-3.5" />
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  const latest = document.querySelector("[data-home-latest]");
  if (latest) {
    const buttons = [...latest.querySelectorAll("[data-home-filter]")];
    const cards = [...latest.querySelectorAll("[data-post-card]")];
    const empty = latest.querySelector("[data-home-empty]");
    const activeClasses = ["border-foreground", "bg-foreground", "text-background"];
    const inactiveClasses = ["border-border", "text-muted-foreground", "hover:text-foreground"];

    const setActive = (button, active) => {
      button.classList.toggle(activeClasses[0], active);
      button.classList.toggle(activeClasses[1], active);
      button.classList.toggle(activeClasses[2], active);
      inactiveClasses.forEach((className) => button.classList.toggle(className, !active));
    };

    const filterCards = (category) => {
      let visible = 0;
      cards.forEach((card) => {
        const match = !category || card.dataset.category === category;
        const show = match && visible < 6;
        card.hidden = !show;
        if (match) visible += 1;
      });
      if (empty) empty.hidden = visible > 0;
      buttons.forEach((button) => setActive(button, button.dataset.homeFilter || ""));
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => filterCards(button.dataset.homeFilter || ""));
    });
  }
</script>
