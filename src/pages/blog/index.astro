---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PostCard from "../../components/PostCard.astro";
import Icon from "../../components/Icon.astro";
import { SITE, categories, sortedPosts, tags } from "../../lib/blog-data.js";

const posts = await sortedPosts();
---

<BaseLayout
  title={`文章 - ${SITE.name}`}
  description="所有文章"
  canonical="/blog"
>
  <div class="mx-auto max-w-4xl px-5 py-12" data-archive>
    <Breadcrumbs items={[{ label: "首页", to: "/" }, { label: "文章" }]} />
    <h1 class="mt-4 font-serif text-4xl font-semibold sm:text-5xl">所有文章</h1>
    <p class="mt-3 max-w-xl text-muted-foreground">
      共 {posts.length} 篇笔记
    </p>

    <form data-archive-search class="mt-8 flex items-center gap-2 border-b border-border pb-2">
      <Icon name="search" class="h-4 w-4 text-muted-foreground" />
      <input
        data-archive-query
        name="q"
        aria-label="搜索文章"
        placeholder="搜索文章..."
        class="w-full border-0 bg-transparent py-2 outline-none placeholder:text-muted-foreground"
      />
      <button
        data-archive-clear
        type="button"
        class="text-xs text-muted-foreground hover:text-foreground"
        hidden
      >
        清除
      </button>
    </form>

    <div class="mt-6 space-y-4 text-sm">
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-xs uppercase tracking-wider text-muted-foreground">分类</span>
        <a data-category-filter="" href="/blog" class="rounded-full border px-3 py-1 text-xs">全部</a>
        {
          categories.map((category) => (
            <a data-category-filter={category.slug} href={`/categories/${category.slug}`} class="rounded-full border px-3 py-1 text-xs">
              {category.name}
            </a>
          ))
        }
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <span class="text-xs uppercase tracking-wider text-muted-foreground">标签</span>
        {
          tags.map((tag) => (
            <a data-tag-filter={tag.slug} href={`/tags/${tag.slug}`} class="rounded-full border px-3 py-1 text-xs">
              #{tag.name}
            </a>
          ))
        }
      </div>
    </div>

    <div data-archive-empty class="mt-12 rounded-md border border-dashed border-border py-16 text-center text-muted-foreground" hidden>
      没有找到匹配的文章。
    </div>

    <div class="mt-2">
      {posts.map((post) => <PostCard post={post} variant="list" />)}
    </div>
  </div>
</BaseLayout>

<script>
  const archive = document.querySelector("[data-archive]");
  if (archive) {
    const query = archive.querySelector("[data-archive-query]");
    const clear = archive.querySelector("[data-archive-clear]");
    const posts = [...archive.querySelectorAll("[data-post-card]")];
    const empty = archive.querySelector("[data-archive-empty]");
    const catLinks = [...archive.querySelectorAll("[data-category-filter]")];
    const tagLinks = [...archive.querySelectorAll("[data-tag-filter]")];

    const filter = () => {
      const q = query.value.toLowerCase();
      let visible = 0;
      posts.forEach((post) => {
        const searchable = post.dataset.search;
        const match = !q || searchable.includes(q);
        post.hidden = !match;
        if (match) visible += 1;
      });
      empty.hidden = visible > 0;
      clear.hidden = !q;
    };

    query.addEventListener("input", filter);

    clear.addEventListener("click", () => {
      query.value = "";
      filter();
      query.focus();
    });

    document.addEventListener("keydown", (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === "k") {
        e.preventDefault();
        query.focus();
      }
    });
  }
</script>
