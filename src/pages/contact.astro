---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { SITE } from "../lib/blog-data.js";
---

<BaseLayout
  title={`联系 - ${SITE.name}`}
  description={`联系 ${SITE.name}`}
  canonical="/contact"
>
  <div class="mx-auto max-w-3xl px-5 py-12">
    <Breadcrumbs items={[{ label: "首页", to: "/" }, { label: "联系" }]} />

    <header class="mt-6">
      <div class="text-xs font-medium uppercase tracking-[0.2em] text-primary">联系</div>
      <h1 class="mt-2 font-serif text-5xl font-semibold">联系我</h1>
    </header>

    <div class="prose-article mt-10">
      <p>欢迎通过以下方式联系：</p>
      <ul>
        <li>GitHub: <a href="https://github.com/yingwu" target="_blank" rel="noopener noreferrer">github.com/yingwu</a></li>
        <li>RSS: <a href="/rss.xml">订阅更新</a></li>
      </ul>
    </div>
  </div>
</BaseLayout>
