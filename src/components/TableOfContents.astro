---
const { items = [] } = Astro.props;
---

{
  items.length > 0 && (
    <div
      id="floating-toc"
      class="fixed right-6 top-1/2 z-40 hidden -translate-y-1/2 rounded-2xl border transition-all duration-500 ease-out lg:block"
      style="border-color: var(--border); background: color-mix(in oklab, var(--background) 75%, transparent); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); box-shadow: 0 8px 32px rgba(0,0,0,0.08); opacity: 0; transform: translateY(-50%) translateX(20px);"
    >
      <div class="flex flex-col gap-3 px-3 py-4">
        {items.map((item, i) => (
          <a
            href={`#${item.id}`}
            data-toc-link={item.id}
            class="group toc-item flex items-center justify-end transition-all duration-300"
            style={{ paddingLeft: item.level === 3 ? "1.5rem" : "0" }}
          >
            <!-- Text label (hidden by default) -->
            <span
              class="toc-label mr-3 whitespace-nowrap text-xs font-medium transition-all duration-300"
              style="color: var(--muted-foreground); opacity: 0; max-width: 0; overflow: hidden;"
            >
              {item.text}
            </span>
            <!-- Horizontal indicator bar -->
            <span
              class="toc-bar block shrink-0 rounded-full transition-all duration-300"
              style="height: 3px; width: 20px; background: var(--border);"
            ></span>
          </a>
        ))}
      </div>
    </div>
  )
}

<style>
  /* Active bar styling */
  .toc-item.is-active .toc-bar {
    background: var(--color-primary) !important;
    width: 28px !important;
  }

  /* Hover expand entire panel */
  #floating-toc:hover {
    transform: translateY(-50%) translateX(0) !important;
    opacity: 1 !important;
  }

  #floating-toc:hover .toc-label {
    opacity: 1 !important;
    max-width: 200px !important;
  }

  #floating-toc:hover .toc-bar {
    width: 24px;
  }

  /* Individual item hover */
  .toc-item:hover .toc-label {
    color: var(--color-foreground) !important;
  }

  .toc-item:hover .toc-bar {
    background: var(--color-foreground) !important;
    width: 24px !important;
  }
</style>

<script>
  (function() {
    var toc = document.getElementById("floating-toc");
    if (!toc) return;

    var links = [...toc.querySelectorAll("[data-toc-link]")];
    var items = links.map(function(l) { return l; });

    // Show TOC with animation on load
    requestAnimationFrame(function() {
      toc.style.opacity = "1";
      toc.style.transform = "translateY(-50%) translateX(0)";
    });

    var setActive = function(id) {
      items.forEach(function(link) {
        var match = link.getAttribute("data-toc-link") === id;
        link.classList.toggle("is-active", match);
      });
    };

    var observer = new IntersectionObserver(
      function(entries) {
        var visible = entries.filter(function(e) { return e.isIntersecting; });
        if (visible.length > 0) setActive(visible[0].target.id);
      },
      { rootMargin: "-80px 0px -70% 0px" }
    );

    items.forEach(function(link) {
      var id = link.getAttribute("data-toc-link");
      var heading = id ? document.getElementById(id) : null;
      if (heading) observer.observe(heading);

      // Click to scroll
      link.addEventListener("click", function(e) {
        e.preventDefault();
        var target = document.getElementById(id);
        if (target) {
          target.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });

    // Hide TOC when at top/bottom of article
    var article = document.querySelector(".prose-article");
    if (article) {
      var updateVisibility = function() {
        var rect = article.getBoundingClientRect();
        var headerH = 100;
        if (rect.bottom < headerH || rect.top > window.innerHeight) {
          toc.style.opacity = "0";
          toc.style.pointerEvents = "none";
        } else {
          toc.style.opacity = "1";
          toc.style.pointerEvents = "auto";
        }
      };
      window.addEventListener("scroll", updateVisibility, { passive: true });
      updateVisibility();
    }
  })();
</script>
