---
const { items = [] } = Astro.props;
---

{
  items.length > 0 && (
    <div data-toc>
      <div class="mb-4 text-[11px] font-medium uppercase tracking-[0.18em] text-muted-foreground">
        On this page
      </div>
      <nav>
        <ul class="space-y-[3px]">
          {items.map((item) => (
            <li>
              <a
                href={`#${item.id}`}
                data-toc-link={item.id}
                class="group relative block rounded-md px-3 py-1.5 text-sm leading-snug transition-all duration-200"
                style={{ paddingLeft: item.level === 3 ? "1.5rem" : "0.75rem" }}
              >
                {item.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  )
}

<style>
  [data-toc-link] {
    color: var(--color-muted-foreground);
  }

  [data-toc-link]:hover {
    color: var(--color-foreground);
    background: color-mix(in oklab, var(--color-muted) 50%, transparent);
  }

  [data-toc-link].is-active {
    color: var(--color-foreground);
    background: color-mix(in oklab, var(--color-primary) 8%, transparent);
    font-weight: 500;
  }

  [data-toc-link].is-active::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 2px;
    height: 16px;
    border-radius: 1px;
    background: var(--color-primary);
  }
</style>

<script>
  const toc = document.querySelector("[data-toc]");
  if (toc) {
    const links = [...toc.querySelectorAll("[data-toc-link]")];

    const setActive = (id) => {
      links.forEach((link) => {
        const match = link.getAttribute("data-toc-link") === id;
        link.classList.toggle("is-active", match);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting);
        if (visible.length > 0) setActive(visible[0].target.id);
      },
      { rootMargin: "-80px 0px -70% 0px" },
    );

    links.forEach((link) => {
      const id = link.getAttribute("data-toc-link");
      const heading = id ? document.getElementById(id) : null;
      if (heading) observer.observe(heading);
    });
  }
</script>
