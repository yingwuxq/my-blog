---
const { items = [] } = Astro.props;
---

{
  items.length > 0 && (
    <div
      id="floating-toc"
      class="fixed right-4 top-1/2 z-40 hidden -translate-y-1/2 rounded-xl border transition-all duration-300 ease-out lg:block"
      style="border-color: var(--border); background: color-mix(in oklab, var(--background) 75%, transparent); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); box-shadow: 0 4px 24px rgba(0,0,0,0.06); opacity: 0;"
    >
      <!-- Toggle button -->
      <button
        id="toc-toggle"
        class="flex w-full items-center justify-center px-2 py-2.5 transition-colors hover:opacity-70"
        style="color: var(--muted-foreground);"
        aria-label="Toggle table of contents"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="6" x2="20" y2="6" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="18" x2="20" y2="18" />
        </svg>
      </button>

      <!-- Content (collapsible) -->
      <div id="toc-content" class="overflow-hidden transition-all duration-300" style="max-height: 0; opacity: 0;">
        <div class="border-t px-2 py-2" style="border-color: var(--border);">
          <div class="mb-1.5 px-2 text-[10px] font-medium uppercase tracking-[0.15em]" style="color: var(--text-tertiary, var(--muted-foreground));">
            On this page
          </div>
          <nav>
            <ul class="space-y-[1px]">
              {items.map((item) => (
                <li>
                  <a
                    href={`#${item.id}`}
                    data-toc-link={item.id}
                    class="toc-item group flex items-center rounded-md px-2 py-1 text-xs leading-snug transition-all duration-200"
                  >
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </div>

      <!-- Bars (always visible, hidden when content is open) -->
      <div id="toc-bars" class="flex flex-col items-center gap-2 px-3 py-3">
        {items.map((item) => (
          <a
            href={`#${item.id}`}
            data-toc-bar-link={item.id}
            class="toc-bar block rounded-full transition-all duration-300"
            style={{
              height: "3px",
              width: item.level === 2 ? "20px" : item.level === 3 ? "14px" : "10px",
              background: "var(--border)",
            }}
          ></a>
        ))}
      </div>
    </div>
  )
}

<style>
  .toc-bar.is-active {
    background: var(--color-primary) !important;
    width: 24px !important;
    height: 4px !important;
  }

  .toc-item {
    color: var(--color-muted-foreground);
  }

  .toc-item:hover {
    color: var(--color-foreground);
    background: color-mix(in oklab, var(--color-muted) 50%, transparent);
  }

  .toc-item.is-active {
    color: var(--color-foreground);
    font-weight: 500;
  }

  .toc-item.is-active::before {
    content: "";
    display: inline-block;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    margin-right: 6px;
    background: var(--color-primary);
  }
</style>

<script>
  (function() {
    var toc = document.getElementById("floating-toc");
    var toggle = document.getElementById("toc-toggle");
    var content = document.getElementById("toc-content");
    var bars = document.getElementById("toc-bars");

    if (!toc || !toggle || !content || !bars) return;

    var expanded = false;

    // Show TOC
    requestAnimationFrame(function() {
      toc.style.opacity = "1";
    });

    // Toggle click
    toggle.addEventListener("click", function() {
      expanded = !expanded;
      if (expanded) {
        content.style.maxHeight = "400px";
        content.style.opacity = "1";
        bars.style.display = "none";
      } else {
        content.style.maxHeight = "0";
        content.style.opacity = "0";
        bars.style.display = "flex";
      }
    });

    // Scroll spy for bars mode
    var barLinks = [...toc.querySelectorAll("[data-toc-bar-link]")];
    var setActiveBar = function(id) {
      barLinks.forEach(function(link) {
        var match = link.getAttribute("data-toc-bar-link") === id;
        link.classList.toggle("is-active", match);
      });
    };

    // Scroll spy for text mode
    var textLinks = [...toc.querySelectorAll("[data-toc-link]")];
    var setActiveText = function(id) {
      textLinks.forEach(function(link) {
        link.classList.toggle("is-active", link.getAttribute("data-toc-link") === id);
      });
    };

    var setActive = function(id) {
      setActiveBar(id);
      setActiveText(id);
    };

    // Observe headings
    var allLinks = barLinks.concat(textLinks);
    var observer = new IntersectionObserver(
      function(entries) {
        var visible = entries.filter(function(e) { return e.isIntersecting; });
        if (visible.length > 0) setActive(visible[0].target.id);
      },
      { rootMargin: "-80px 0px -70% 0px" }
    );

    allLinks.forEach(function(link) {
      var id = link.getAttribute("data-toc-link") || link.getAttribute("data-toc-bar-link");
      var heading = id ? document.getElementById(id) : null;
      if (heading) observer.observe(heading);

      link.addEventListener("click", function(e) {
        e.preventDefault();
        var target = document.getElementById(id);
        if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    // Show/hide based on article visibility
    var article = document.querySelector(".prose-article");
    if (article) {
      var updateVis = function() {
        var rect = article.getBoundingClientRect();
        if (rect.bottom < 100 || rect.top > window.innerHeight) {
          toc.style.opacity = "0";
          toc.style.pointerEvents = "none";
        } else {
          toc.style.opacity = "1";
          toc.style.pointerEvents = "auto";
        }
      };
      window.addEventListener("scroll", updateVis, { passive: true });
      updateVis();
    }
  })();
</script>
