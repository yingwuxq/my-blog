---
import Icon from "./Icon.astro";
import { SITE, categories } from "../lib/blog-data.js";
import { SOCIAL_LINKS } from "../config/theme.config.ts";

const { flush = false, scenery = false } = Astro.props;
---

<footer class:list={[flush ? "mt-0" : "mt-24", "relative overflow-hidden"]}>
  {scenery && (
    <div class="absolute inset-0 -z-10">
      <picture>
        <source srcSet="/assets/light-finale.avif" media="(prefers-color-scheme: light)" />
        <img
          src="/assets/dark-finale.avif"
          alt=""
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </picture>
      <div class="absolute inset-0 bg-gradient-to-t from-background/95 via-background/70 to-background/40 dark:from-background/95 dark:via-background/70 dark:to-background/40" />
    </div>
  )}

  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-16 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="font-serif text-lg font-semibold" style="color: var(--foreground)">
        {SITE.name}
      </div>
      <p class="mt-3 max-w-sm text-sm leading-relaxed" style="color: var(--muted-foreground)">
        {SITE.description}
      </p>
      <div class="mt-4 flex items-center gap-3" style="color: var(--muted-foreground)">
        {
          SOCIAL_LINKS.map((link) => (
            <a href={link.href} aria-label={link.label} class="hover:text-foreground transition-colors">
              <Icon name={link.icon} class="h-4 w-4" />
            </a>
          ))
        }
      </div>
    </div>
    <div>
      <div class="text-xs font-medium uppercase tracking-wider" style="color: var(--muted-foreground)">分类</div>
      <ul class="mt-3 space-y-2 text-sm">
        {
          categories.slice(0, 5).map((category) => (
            <li>
              <a href={`/categories/${category.slug}`} class="transition-colors" style="color: color-mix(in oklab, var(--foreground) 80%, transparent)">
                {category.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div>
      <div class="text-xs font-medium uppercase tracking-wider" style="color: var(--muted-foreground)">链接</div>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/about" class="transition-colors" style="color: color-mix(in oklab, var(--foreground) 80%, transparent)">关于</a></li>
        <li><a href="/contact" class="transition-colors" style="color: color-mix(in oklab, var(--foreground) 80%, transparent)">联系</a></li>
        <li><a href="/blog" class="transition-colors" style="color: color-mix(in oklab, var(--foreground) 80%, transparent)">文章</a></li>
        <li><a href="/rss.xml" class="transition-colors" style="color: color-mix(in oklab, var(--foreground) 80%, transparent)">RSS</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t" style="border-color: var(--border)">
    <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-2 px-5 py-5 text-xs sm:flex-row sm:items-center" style="color: var(--muted-foreground)">
      <div>&copy; {new Date().getFullYear()} {SITE.name}.</div>
      <div>Set in Fraunces &amp; Inter.</div>
    </div>
  </div>
</footer>
